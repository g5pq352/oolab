{
  "name": "tailwind-scss-browsersync-wamp",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "watch:sass": "sass sass/style.scss .tmp/style.css --style=expanded --no-source-map --watch",
    "watch:postcss": "postcss .tmp/style.css -o stylesheets/style.css --no-map --no-cache --watch",
    "watch:js": "nodemon --config nodemon.json --quiet",
    "serve": "browser-sync start --config bs-config.js",
    "dev": "npm-run-all2 --parallel watch:sass watch:postcss watch:js serve",
    "build:sass": "sass sass/style.scss .tmp/style.css --style=compressed --no-source-map",
    "build:css": "postcss .tmp/style.css -o stylesheets/style.css --no-map",
    "build:js": "powershell -Command \"Get-ChildItem src/*.js | ForEach-Object { npx terser $_.FullName -o ($_.FullName -replace 'src', 'dist') --compress --mangle }\"",
    "build": "npm-run-all2 build:sass build:css build:js"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "browser-sync": "^3.0.4",
    "cssnano": "^7.0.6",
    "nodemon": "^3.1.11",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.4.47",
    "postcss-cli": "^11.0.0",
    "sass": "^1.80.3",
    "tailwindcss": "^3.4.14",
    "terser": "^5.36.0"
  }
}
